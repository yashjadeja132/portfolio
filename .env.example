# ------------------------------------------------------------------
# Copy this file to `.env.local` (local dev) and set the same values
# in your Vercel project settings (Production + Preview).
# ------------------------------------------------------------------

# Canonical base URL for SEO (metadata, canonical links, sitemap,
# Open Graph / Twitter image URLs, JSON-LD). No trailing slash.
# On Vercel this auto-falls back to your production domain if unset,
# but setting it explicitly is recommended.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ------------------------------------------------------------------
# Contact form (POST /api/contact) — SMTP via Nodemailer.
# Gmail example (use an App Password, not your login):
#   https://support.google.com/accounts/answer/185833
# If unset, the API returns a friendly error and the UI degrades.
# ------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password

# Where contact messages are delivered, and the From header shown.
CONTACT_TO=yashrajsinhjadeja757@gmail.com
CONTACT_FROM="Portfolio Contact <your-address@gmail.com>"
