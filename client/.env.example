# Client (Vite) env — copy to client/.env for local dev.
# Only VITE_* vars are read by the client. The API (SMTP etc.) is the
# separate server/ project.

# Canonical URL for SEO / OG (no trailing slash) — your deployed site URL.
VITE_SITE_URL=https://yashjadeja132.github.io/portfolio

# Base URL of the deployed API (Render). Leave EMPTY for local dev — the Vite
# proxy forwards /api. The GitHub Actions build sets this for production.
VITE_API_URL=
