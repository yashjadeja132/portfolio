# Copy to client/.env (git-ignored) and set real values.
# The api (client/api/index.js) reads client/.env; on a host set these in the
# platform's env settings instead.

# Canonical URL for SEO / sitemap / OG (no trailing slash) — your deployed URL.
VITE_SITE_URL=https://your-domain.com
SITE_URL=https://your-domain.com

# API server port. Locally avoid 5000 (used by another app) and 6000
# (blocked by Chrome as an unsafe port). Hosts inject their own PORT.
PORT=4000

# Contact form (Nodemailer). Gmail: use an App Password, not your login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO=your-address@gmail.com
CONTACT_FROM="Portfolio Contact <your-address@gmail.com>"
